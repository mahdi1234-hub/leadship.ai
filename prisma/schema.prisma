generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  leads         Lead[]
  savedLists    SavedList[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  title       String?
  company     String?
  companyLogo String?
  email       String?
  phone       String?
  emailStatus String   @default("unknown")
  phoneStatus String   @default("unknown")
  intentScore Int      @default(0)
  intentLevel String   @default("Cold")
  source      String?
  linkedinUrl String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listItems   ListItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SavedList {
  id        String     @id @default(cuid())
  name      String
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ListItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model ListItem {
  id        String    @id @default(cuid())
  leadId    String
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  listId    String
  list      SavedList @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([leadId, listId])
}
